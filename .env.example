# =============================================================================
# CloudSyncPro — Environment variables
# =============================================================================
# Copy this file to `.env.local` (development) or set the same vars in your
# hosting provider's dashboard (Vercel → Settings → Environment Variables).
#
# IMPORTANT: only variables prefixed with VITE_ are exposed to the browser.
# Anything sensitive (R2 secrets, service role key, cron secret) should NEVER
# have the VITE_ prefix and should NEVER be referenced from /src.
# =============================================================================

# --- Supabase (REQUIRED for client) ---
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# --- Cloudflare R2 public URL (REQUIRED for client to display files) ---
# Public read-only URL for your R2 bucket (custom domain or pub.r2.dev URL).
VITE_R2_PUBLIC_URL=https://files.your-domain.com

# --- Sentry (OPTIONAL — leave empty to disable error monitoring) ---
# Get your DSN from sentry.io → Project Settings → Client Keys (DSN).
# When empty, the app runs normally without sending any data to Sentry.
VITE_SENTRY_DSN=

# =============================================================================
# Below this line: server-side only — used by Supabase Edge Functions.
# Set these in Supabase Dashboard → Edge Functions → Secrets, NOT here for prod.
# Listed for documentation only.
# =============================================================================

# R2 (server-side, never exposed to browser)
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=cloudsyncpro

# Supabase service role (server-side only, edge functions)
# SUPABASE_SERVICE_ROLE_KEY=

# Cron secret for purge-files auto_purge mode
# CRON_SECRET=
